<%# Driver Registration EJS View %>
<div class="page-header">
  <h2>Register Driver</h2>
  <p>Add a new driver to the transport management system</p>
</div>

<div class="form-card">
  <% if (success) { %>
  <div class="alert alert-success show"><%= success %></div>
  <% } %>
  <% if (error) { %>
  <div class="alert alert-danger show"><%= error %></div>
  <% } %>

  <form action="/driver-register" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-control" placeholder="e.g. Rajinder Singh" value="<%= formData.name || '' %>" required />
      </div>
      <div class="form-group">
        <label class="form-label">Phone Number</label>
        <input type="tel" name="phone" class="form-control" placeholder="e.g. +91 98765 43210" value="<%= formData.phone || '' %>" required />
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">License Number</label>
      <input type="text" name="license_no" class="form-control" placeholder="e.g. PB-0520220123456" value="<%= formData.license_no || '' %>" required />
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Register Driver</button>
      <a href="/drivers" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>