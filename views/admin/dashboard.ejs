<%# Admin Dashboard EJS View %>
<div class="welcome-banner">
  <div class="welcome-text">
    <h2>Admin Dashboard</h2>
    <p>CGC University Transport Management System &mdash; Control Center</p>
  </div>
  <div class="welcome-icon">
    <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon navy">
      <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-number"><%= stats.total_students %></div>
      <div class="stat-label">Total Students</div>
      <div class="stat-change up">Registered</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon maroon">
      <svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4z"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-number"><%= stats.total_drivers %></div>
      <div class="stat-label">Total Drivers</div>
      <div class="stat-change up">Registered</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon success">
      <svg viewBox="0 0 24 24"><path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8H4v8z"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-number"><%= stats.total_routes %></div>
      <div class="stat-label">Active Bus Routes</div>
      <div class="stat-change neutral">Routes</div>
    </div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
  <div class="card">
    <div class="card-header"><h3>Recent Students</h3><a href="/students" class="btn btn-primary btn-sm">View All</a></div>
    <div class="table-wrapper">
      <table>
        <thead><tr><th>#</th><th>Name</th><th>Bus No.</th></tr></thead>
        <tbody>
          <% recent_students.forEach((s, i) => { %>
          <tr>
            <td><span class="badge badge-navy"><%= i+1 %></span></td>
            <td class="td-name"><%= s.name %></td>
            <td><span class="badge badge-maroon"><%= s.bus_no %></span></td>
          </tr>
          <% }) %>
          <% if (!recent_students.length) { %>
          <tr><td colspan="3" style="text-align:center;color:#999;padding:24px;">No students yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header"><h3>Recent Drivers</h3><a href="/drivers" class="btn btn-primary btn-sm">View All</a></div>
    <div class="table-wrapper">
      <table>
        <thead><tr><th>#</th><th>Name</th><th>License</th></tr></thead>
        <tbody>
          <% recent_drivers.forEach((d, i) => { %>
          <tr>
            <td><span class="badge badge-navy"><%= i+1 %></span></td>
            <td class="td-name"><%= d.name %></td>
            <td><span class="badge badge-success"><%= d.license_no %></span></td>
          </tr>
          <% }) %>
          <% if (!recent_drivers.length) { %>
          <tr><td colspan="3" style="text-align:center;color:#999;padding:24px;">No drivers yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>